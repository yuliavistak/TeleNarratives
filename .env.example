# DisinfoGraph Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains sensitive credentials

# ============================================
# Telegram API Credentials
# ============================================
# Get these from https://my.telegram.org
# 1. Go to https://my.telegram.org
# 2. Log in with your phone number
# 3. Go to "API development tools"
# 4. Create a new application (if needed)
# 5. Copy api_id and api_hash here
TELEGRAM_API_ID=your_telegram_api_id_here
TELEGRAM_API_HASH=your_telegram_api_hash_here

# ============================================
# Neo4j Database Credentials
# ============================================
# For Neo4j Aura or self-hosted Neo4j instance
# Format for Aura: neo4j+s://xxxxx.databases.neo4j.io
# Format for local: neo4j://localhost:7687
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j



OPENAI_API_KEY = Your_OpenAI_API_key_here
GEMINI_API_KEY = Your_Gemini_API_key_here
ANTHROPIC_API_KEY = Your_Anthropic_API_key_here